{
  "$id": "https://sanmon.dev/schemas/agent-action.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema for a coding agent's own tool calls (shell, file, network, MCP)",
  "properties": {
    "action_type": {
      "enum": [
        "shell_exec",
        "file_write",
        "file_edit",
        "file_read",
        "net_fetch",
        "mcp_call"
      ],
      "type": "string"
    },
    "context": {
      "properties": {
        "authenticated": {
          "type": "boolean"
        },
        "domain": {
          "enum": [
            "browser",
            "api",
            "database",
            "iac",
            "approval",
            "agent"
          ],
          "type": "string"
        },
        "session_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "authenticated",
        "session_id",
        "domain"
      ],
      "type": "object"
    },
    "metadata": {
      "properties": {
        "agent_id": {
          "minLength": 1,
          "type": "string"
        },
        "request_id": {
          "minLength": 1,
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "timestamp",
        "agent_id",
        "request_id"
      ],
      "type": "object"
    },
    "parameters": {
      "type": "object"
    },
    "target": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "action_type",
    "target",
    "parameters",
    "context",
    "metadata"
  ],
  "title": "Agent Action",
  "type": "object"
}
