{
  "$id": "https://sanmon.dev/schemas/approval-action.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema for document approval workflow actions",
  "properties": {
    "action_type": {
      "enum": [
        "approve",
        "reject"
      ],
      "type": "string"
    },
    "context": {
      "properties": {
        "authenticated": {
          "type": "boolean"
        },
        "domain": {
          "enum": [
            "browser",
            "api",
            "database",
            "iac",
            "approval",
            "agent"
          ],
          "type": "string"
        },
        "session_id": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "authenticated",
        "session_id",
        "domain"
      ],
      "type": "object"
    },
    "metadata": {
      "properties": {
        "agent_id": {
          "minLength": 1,
          "type": "string"
        },
        "request_id": {
          "minLength": 1,
          "type": "string"
        },
        "timestamp": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "timestamp",
        "agent_id",
        "request_id"
      ],
      "type": "object"
    },
    "parameters": {
      "properties": {
        "document": {
          "properties": {
            "amount": {
              "type": "number"
            },
            "applicant": {
              "type": "string"
            },
            "category": {
              "type": "string"
            },
            "department": {
              "type": "string"
            },
            "id": {
              "minLength": 1,
              "type": "string"
            },
            "submitted_date": {
              "type": "string"
            },
            "title": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "amount"
          ],
          "type": "object"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "document"
      ],
      "type": "object"
    },
    "target": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "action_type",
    "target",
    "parameters",
    "context",
    "metadata"
  ],
  "title": "Approval Action",
  "type": "object"
}
